{
  "manifest_version": 3,
  "name": "SwitchBot Controller",
  "version": "1.0.2",
  "description": "SwitchBotデバイスをブラウザから操作・監視できる拡張機能",
  "permissions": ["storage"],
  "host_permissions": ["https://api.switch-bot.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SwitchBot Controller",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
